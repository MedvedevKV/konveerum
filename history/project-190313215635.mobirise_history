s=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div class=\"container\">\n        <div class=\"media-container-row\">\n            <div class=\"col-md-8 align-center\">\n                <h2 class=\"pb-3 mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">Присоединяйтесь сами и зовите своих коллег!</h2>\n                <div class=\"social-list pl-0 mb-0\">\n                    <a href=\"https://vk.com/konveerum\" target=\"_blank\">\n                        <span mbr-icon class=\"px-2 mbr-iconfont mbr-iconfont-social socicon-vkontakte socicon\" style=\"font-size: 66px;\"></span>\n                    </a>\n                    <a href=\"https://www.facebook.com/groups/konveerum\" target=\"_blank\">\n                        <span mbr-icon class=\"px-2 mbr-iconfont mbr-iconfont-social socicon-facebook socicon\" mbr-if=\"iconsCount > 1\" style=\"font-size: 66px;\"></span>\n                    </a>\n                    <a href=\"https://www.youtube.com/channel/UCFXgwJmGEC2ckDFeZDpKxZQ\" target=\"_blank\">\n                        <span mbr-icon class=\"px-2 mbr-iconfont mbr-iconfont-social socicon-youtube socicon\" mbr-if=\"iconsCount > 2\" style=\"font-size: 66px;\"></span>\n                    </a>\n                    <a href=\"https://t.me/joinchat/DseFx0zVKCsgTGeEC0N0hA\" target=\"_blank\">\n                        <span mbr-icon class=\"px-2 mbr-iconfont mbr-iconfont-social socicon-telegram socicon\" mbr-if=\"iconsCount > 3\" style=\"font-size: 66px;\"></span>\n                    </a>\n                    <a href=\"https://www.instagram.com/konveerum/\" target=\"_blank\">\n                        <span mbr-icon class=\"px-2 mbr-iconfont mbr-iconfont-social socicon-instagram socicon\" mbr-if=\"iconsCount > 4\" style=\"font-size: 66px;\"></span>\n                    </a>\n                    <a href=\"https://www.behance.net/Mobirise\" target=\"
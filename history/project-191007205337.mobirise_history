minutesCountdown\"></div>\n            <div title=\"{{secondsCountdown}}\" class=\"secondsCountdown\"></div>\n            <div class=\"event-date align-left mbr-white\" mbr-if=\"showDate\">\n                <h5 class=\"mbr-fonts-style\" mbr-theme-style=\"display-5\">29 октября 2019, 17:00 - 19:00 (GMT +7)</h5>\n            </div>\n        </div>\n\n        <div class=\"media-container-row pt-5\" mbr-if=\"showButtons\">\n            <div class=\"mbr-section-btn align-center\" mbr-buttons mbr-theme-style=\"display-4\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-secondary\" href=\"https://leader-id.ru/event/29735/\" data-app-placeholder=\"Введите Текст\" target=\"_blank\">Регистрация<br>(Leader ID)<br></a> <a class=\"btn btn-secondary\" href=\"https://forms.gle/WwrE62ugQEiqYagS9\" data-app-placeholder=\"Введите Текст\" target=\"_blank\">Регистрация<br>(Google Forms)<br></a> <a class=\"btn btn-primary\" href=\"mailto:info@konveerum.ru\" data-app-placeholder=\"Введите Текст\">Хочу выступить</a></div>\n        </div>\n    </div>\n</section>",
